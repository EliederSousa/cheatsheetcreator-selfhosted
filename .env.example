################################
# MongoDB Settings
################################
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=my-secret-pass
MONGO_DATABASE=my-cheatsheetdb
MONGO_PORT=9000

API_PORT=9001

################################
# Security Settings
################################
# Leave it blank if you want no protection to API (local and personal use)
API_KEY=my-secret-key
# Put all domains allowed to host the frontend, separated by commas. Ex: localhost:9002, my.domain.com
CORS_ALLOWED_ORIGINS=*
# Use this variable to limit the ammount of requests/minute to the API (must be positive). 
RATE_LIMIT=100